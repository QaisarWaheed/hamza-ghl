# MongoDB — Atlas (recommended) or local with replica set (Prisma needs replica set for some writes)
# Atlas: mongodb+srv://USER:PASS@cluster.mongodb.net/ghl_portfolio
DATABASE_URL="mongodb://127.0.0.1:27017/ghl_portfolio"

# Auth — generate hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="$2b$10$urgNw102db2fOKjubmTrEuoP83qyj9jY8Adxx5dye7rJ1XTbxSxR6"

# JWT for admin session (min 16 chars; use a long random string in production)
JWT_SECRET="change-me-to-a-long-random-secret"

# Optional: canonical site URL for Open Graph metadata
# NEXT_PUBLIC_SITE_URL="https://your-domain.com"
